FEISHU_APP_ID=cli_a9228e48dc395cce
FEISHU_APP_SECRET=WB6gM2hSw0pn8KREoF2cCbcbskwFX26B
# FEISHU_FOLDER_TOKEN=
FEISHU_APP_ALERT_ENABLED=true
FEISHU_APP_RECEIVE_ID_TYPE=chat_id
FEISHU_APP_RECEIVE_IDS=oc_47771202fa15f1899117c74e9bcc927c
