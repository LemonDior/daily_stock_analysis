# ===================================
# A股自选股智能分析系统 - 统一配置模板
# 复制此文件为 .env 后按需启用对应配置
# 本文件按模块分组，尽量收口仓库内所有可用环境变量
# ===================================

# ===================================
# 基础配置
# ===================================

# 指定自定义 .env 路径；通常不需要配置
# ENV_FILE=./.env

# 自选股列表，逗号分隔；支持 A 股 / 港股 / 美股代码
STOCK_LIST=600519,300750,002594

# 是否保存分析上下文快照，便于历史回溯和排障
SAVE_CONTEXT_SNAPSHOT=true


# ===================================
# 数据库配置
# ===================================

# 默认使用本地 SQLite
DATABASE_PATH=./data/stock_analysis.db

# 如需切换 MySQL，优先配置 DATABASE_URL；配置后会忽略 DATABASE_PATH
# 支持 mysql://，程序会自动补齐为 SQLAlchemy 可用格式
DATABASE_URL=mysql+pymysql://root:lM%3F124646@175.178.14.241:3306/stock?charset=utf8mb4


# ===================================
# AI 模型配置
# ===================================
# 完整说明见 docs/LLM_CONFIG_GUIDE.md
# 快速上手：至少填一个 API Key 即可运行
# 进阶场景：统一推荐使用 LLM_CHANNELS + LLM_<NAME>_* 这组字段

# 主模型，格式为 provider/model，例如 gemini/gemini-2.5-flash
# 留空时会根据已配置的 API Key 自动推断
LITELLM_MODEL=openai/glm-4.6v

# 主模型失败时的兜底模型列表，逗号分隔
# LITELLM_FALLBACK_MODELS=anthropic/claude-3-5-sonnet-20241022,openai/gpt-4o-mini

# 全局统一温度；若配置，优先级高于各家单独温度
# LLM_TEMPERATURE=0.7

# 高级模式：直接指定 LiteLLM Router YAML 配置文件
# LITELLM_CONFIG=./litellm_config.yaml

# 多渠道名称列表，逗号分隔；Web 设置页与 .env 共用这套字段
# LLM_CHANNELS=primary,backup
#
# 渠道字段命名规则：
# LLM_<NAME>_PROTOCOL=openai
# LLM_<NAME>_BASE_URL=https://api.example.com/v1
# LLM_<NAME>_API_KEY=sk-xxx
# LLM_<NAME>_API_KEYS=sk-a,sk-b
# LLM_<NAME>_MODELS=gpt-4o-mini,claude-3-5-sonnet
# LLM_<NAME>_ENABLED=true

# 聚合平台：一个 Key 走多模型
# AIHUBMIX_KEY=

# Gemini
GEMINI_API_KEY=
# GEMINI_API_KEYS=key1,key2
# GEMINI_MODEL=gemini-3-flash-preview
# GEMINI_MODEL_FALLBACK=gemini-2.5-flash
# GEMINI_TEMPERATURE=0.7
# GEMINI_REQUEST_DELAY=2.0
# GEMINI_MAX_RETRIES=5
# GEMINI_RETRY_DELAY=5.0

# DeepSeek 官方接口
# DEEPSEEK_API_KEY=
# DEEPSEEK_API_KEYS=key1,key2

# Anthropic Claude
# ANTHROPIC_API_KEY=
# ANTHROPIC_API_KEYS=key1,key2
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# ANTHROPIC_TEMPERATURE=0.7
# ANTHROPIC_MAX_TOKENS=8192

# OpenAI / OpenAI 兼容接口
OPENAI_API_KEY=12651fbe6b5e483e9f5e8772c668b3e8.WeaKGiglerB8H3Nm
# OPENAI_API_KEYS=key1,key2
OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
OPENAI_MODEL=glm-4.6v
OPENAI_VISION_MODEL=glm-4.6v
# OPENAI_TEMPERATURE=0.7

# Vision 专用配置
# 不配时会按 VISION_MODEL -> OPENAI_VISION_MODEL -> 默认 Gemini 兜底
VISION_MODEL=openai/glm-4.6v
VISION_PROVIDER_PRIORITY=openai


# ===================================
# 搜索与情报配置
# ===================================
# 用于新闻、事件、舆情补充信息

# Tushare Pro Token
TUSHARE_TOKEN=d0ad31a980c2dbed4eefe16cbbbd1b79adc95954fdf64e51ee921a2c

# 搜索引擎 Key，支持多个时用逗号分隔
# BOCHA_API_KEYS=
# MINIMAX_API_KEYS=
TAVILY_API_KEYS=
SERPAPI_API_KEYS=
BRAVE_API_KEYS=
SEARXNG_BASE_URLS=

# 美股社交舆情数据，仅对美股代码生效
# SOCIAL_SENTIMENT_API_KEY=
# SOCIAL_SENTIMENT_API_URL=https://api.adanos.org

# 新闻窗口控制
NEWS_STRATEGY_PROFILE=short
NEWS_MAX_AGE_DAYS=3

# 乖离率阈值（%）
BIAS_THRESHOLD=5.0


# ===================================
# Agent 策略配置
# ===================================

# 是否启用 Agent 策略问股模式
AGENT_MODE=true

# Agent 最多推理步数
AGENT_MAX_STEPS=10

# 默认启用的策略，逗号分隔；all 表示启用全部内置策略
AGENT_SKILLS=bull_trend,ma_golden_cross,volume_breakout,shrink_pullback

# 自定义策略目录
AGENT_STRATEGY_DIR=./strategies

# Bot 自然语言路由开关
# AGENT_NL_ROUTING=false

# Agent 架构：single / multi
# AGENT_ARCH=single

# 多 Agent 编排模式：quick / standard / full / strategy
# AGENT_ORCHESTRATOR_MODE=standard

# 多 Agent 超时预算，单位秒
# AGENT_ORCHESTRATOR_TIMEOUT_S=600

# 风控 Agent 是否允许否决买入信号
# AGENT_RISK_OVERRIDE=true

# 深度研究预算与超时
# AGENT_DEEP_RESEARCH_BUDGET=30000
# AGENT_DEEP_RESEARCH_TIMEOUT=180

# 记忆与回测加权
# AGENT_MEMORY_ENABLED=false
# AGENT_STRATEGY_AUTOWEIGHT=true

# 策略路由：auto / manual
# AGENT_STRATEGY_ROUTING=auto

# 告警后台轮询
# AGENT_EVENT_MONITOR_ENABLED=false
# AGENT_EVENT_MONITOR_INTERVAL_MINUTES=5
# AGENT_EVENT_ALERT_RULES_JSON=[{"rule_id":"moutai_break_1800","stock_code":"600519","alert_type":"price_cross","direction":"above","price":1800,"cooldown_minutes":30}]


