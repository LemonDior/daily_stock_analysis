# ===================================
# 回测配置
# ===================================

BACKTEST_ENABLED=true
BACKTEST_EVAL_WINDOW_DAYS=10
BACKTEST_MIN_AGE_DAYS=14
BACKTEST_ENGINE_VERSION=v1
BACKTEST_NEUTRAL_BAND_PCT=2.0


# ===================================
# 定时任务与复盘配置
# ===================================

SCHEDULE_ENABLED=false
SCHEDULE_TIME=18:00

# schedule 模式启动时是否立即先跑一次
SCHEDULE_RUN_IMMEDIATELY=true

# 非 schedule 模式启动时是否立即执行一次分析
RUN_IMMEDIATELY=true

# 交易日检查与大盘复盘
MARKET_REVIEW_ENABLED=true
# MARKET_REVIEW_REGION=cn
# TRADING_DAY_CHECK_ENABLED=true

# A 股主数据周更任务
# CN_STOCK_MASTER_SYNC_ENABLED=false
# CN_STOCK_MASTER_SYNC_TIME=20:00


# ===================================
# 运行时代理与网络配置
# ===================================

# 方式一：项目内简化代理开关，仅 main.py 本地启动路径会读取
USE_PROXY=false
PROXY_HOST=127.0.0.1
PROXY_PORT=10809

# 方式二：标准 HTTP(S)_PROXY，适用于 requests / aiohttp / 第三方库
# HTTP_PROXY=http://127.0.0.1:10809
# HTTPS_PROXY=http://127.0.0.1:10809

# 明确排除不走代理的域名，逗号分隔
# NO_PROXY=127.0.0.1,localhost


# ===================================
# 系统运行与校验配置
# ===================================

LOG_DIR=./logs
LOG_LEVEL=INFO
MAX_WORKERS=3
DEBUG=false

# 配置校验模式：warn / strict
# CONFIG_VALIDATE_MODE=warn


# ===================================
# WebUI / API / 认证配置
# ===================================

# WebUI 服务
WEBUI_ENABLED=false
WEBUI_HOST=127.0.0.1
WEBUI_PORT=8000

# 启动 Web 服务前是否自动构建前端
WEBUI_AUTO_BUILD=true

# 反向代理下信任 X-Forwarded-For 获取真实 IP
# TRUST_X_FORWARDED_FOR=false

# 管理员认证
ADMIN_AUTH_ENABLED=false
# ADMIN_SESSION_MAX_AGE_HOURS=24

# CORS
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# CORS_ALLOW_ALL=false


